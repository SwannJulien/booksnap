# ==============================================
# BOOKSNAP - Configuration Template
# ==============================================
# Copy this file to .env and fill in the values
# > cp .env.example .env
# ==============================================

# ----------------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------------
DB_PORT=5432
POSTGRES_USER=booksnap
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=booksnap_db

# ----------------------------------------------
# PGADMIN (Database Management Interface)
# ----------------------------------------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@booksnap.com
PGADMIN_DEFAULT_PASSWORD=changeme_admin_password

# ----------------------------------------------
# BACKEND (Spring Boot)
# ----------------------------------------------
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# Database host
# - Local (outside Docker): localhost
# - Docker Compose: db (service name)
DB_HOST=db

# ----------------------------------------------
# FRONTEND (Lit + Vite)
# ----------------------------------------------
FRONTEND_PORT=3000

# Backend API URL
# - Local dev: http://localhost:8080
# - Docker: http://localhost:8080 (exposed on host)
# - Production: https://api.booksnap.example.com (adjust as needed)
VITE_API_BASE_URL=http://localhost:8080
